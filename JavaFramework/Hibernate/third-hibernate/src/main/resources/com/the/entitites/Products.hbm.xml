<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.the.entitites">
    <class name="Products" table="products">
        <id name="productNo" column="product_no"/>
        <property name="productName" column="product_nm"/>
        <property name="description"/>
        <property name="manufactureName" column="manufacture_nm"/>
        <property name="categoryName" column="category_nm"/>
        <property name="price"/>
    </class>
</hibernate-mapping>